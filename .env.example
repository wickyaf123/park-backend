OPENAI_API_KEY=sk-replace-me
OPENAI_REALTIME_MODEL=gpt-4o-realtime-preview-2024-12-17
# Voice options: alloy, ash, ballad, coral, echo, sage, shimmer, verse.
# `ballad` and `sage` are the most British-leaning. Hot-swap by editing this
# value and restarting uvicorn — no code change needed.
OPENAI_REALTIME_VOICE=ballad
PORT=8000
ALLOWED_ORIGIN=http://localhost:5500
